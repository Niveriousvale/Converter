<script>
  const drop = document.getElementById('drop');
  const fileInput = document.getElementById('file');
  const controls = document.getElementById('controls');
  const filesEl = document.getElementById('files');
  const fmt = document.getElementById('fmt');
  const quality = document.getElementById('quality');
  const qval = document.getElementById('qval');
  const qrow = document.getElementById('qrow');
  const maxw = document.getElementById('maxw');
  const go = document.getElementById('go');

  let queue = [];

  function fmtSize(b) {
    if (b < 1024) return b + ' B';
    if (b < 1048576) return (b / 1024).toFixed(1) + ' KB';
    return (b / 1048576).toFixed(2) + ' MB';
  }
  function ext(mime) {
    return mime === 'image/jpeg' ? 'jpg' : mime === 'image/webp' ? 'webp' : 'png';
  }

  drop.addEventListener('click', () => fileInput.click());
  drop.addEventListener('dragover', e => { e.preventDefault(); drop.classList.add('over'); });
  drop.addEventListener('dragleave', () => drop.classList.remove('over'));
  drop.addEventListener('drop', e => {
    e.preventDefault(); drop.classList.remove('over');
    handleFiles(e.dataTransfer.files);
  });
  fileInput.addEventListener('change', e => handleFiles(e.target.files));

  function handleFiles(list) {
    queue = Array.from(list).filter(f => f.type.startsWith('image/'));
    if (!queue.length) return;
    controls.classList.add('show');
    renderQueue();
  }

  function renderQueue() {
    filesEl.innerHTML = '';
    queue.forEach(f => {
      const url = URL.createObjectURL(f);
      const row = document.createElement('div');
      row.className = 'file';
      row.innerHTML =
        '<img class="thumb" src="' + url + '" />' +
        '<div class="fmeta"><div class="fname">' + f.name + '</div>' +
        '<div class="fsize">' + fmtSize(f.size) + '</div></div>';
      filesEl.appendChild(row);
    });
  }

  // hide quality slider for PNG (lossless — quality has no effect)
  fmt.addEventListener('change', () => {
    qrow.style.display = fmt.value === 'image/png' ? 'none' : 'flex';
  });
  quality.addEventListener('input', () => qval.textContent = quality.value + '%');

  go.addEventListener('click', async () => {
    if (!queue.length) return;
    go.disabled = true;
    go.textContent = 'Converting…';
    filesEl.innerHTML = '';

    for (const f of queue) {
      try {
        const out = await convert(f);
        addResult(f, out);
      } catch (err) {
        const row = document.createElement('div');
        row.className = 'file';
        row.innerHTML = '<div class="fmeta"><div class="fname">' + f.name +
          '</div><div class="fsize">Could not convert this file</div></div>';
        filesEl.appendChild(row);
      }
    }
    go.disabled = false;
    go.textContent = 'Convert';
  });

  function convert(file) {
    return new Promise((resolve, reject) => {
      const img = new Image();
      const url = URL.createObjectURL(file);
      img.onload = () => {
        let w = img.naturalWidth, h = img.naturalHeight;
        const limit = parseInt(maxw.value, 10);
        if (limit && w > limit) { h = Math.round(h * limit / w); w = limit; }

        const canvas = document.createElement('canvas');
        canvas.width = w; canvas.height = h;
        const ctx = canvas.getContext('2d');
        // white backing for JPG (no alpha) so transparency doesn't go black
        if (fmt.value === 'image/jpeg') {
          ctx.fillStyle = '#ffffff';
          ctx.fillRect(0, 0, w, h);
        }
        ctx.drawImage(img, 0, 0, w, h);
        URL.revokeObjectURL(url);

        const q = parseInt(quality.value, 10) / 100;
        const type = fmt.value;
        const args = type === 'image/png' ? [type] : [type, q];

        // dataURL -> Blob fallback for environments where toBlob is blocked
        const viaDataURL = () => {
          try {
            const dataURL = canvas.toDataURL.apply(canvas, args);
            const comma = dataURL.indexOf(',');
            const bytes = atob(dataURL.slice(comma + 1));
            const buf = new Uint8Array(bytes.length);
            for (let i = 0; i < bytes.length; i++) buf[i] = bytes.charCodeAt(i);
            resolve(new Blob([buf], { type: type }));
          } catch (e) {
            reject(new Error('conversion blocked'));
          }
        };

        if (typeof canvas.toBlob === 'function') {
          let settled = false;
          const timer = setTimeout(() => { if (!settled) { settled = true; viaDataURL(); } }, 1500);
          try {
            canvas.toBlob(blob => {
              if (settled) return;
              settled = true;
              clearTimeout(timer);
              blob ? resolve(blob) : viaDataURL();
            }, type, type === 'image/png' ? undefined : q);
          } catch (e) {
            if (!settled) { settled = true; clearTimeout(timer); viaDataURL(); }
          }
        } else {
          viaDataURL();
        }
      };
      img.onerror = () => { URL.revokeObjectURL(url); reject(new Error('load failed')); };
      img.src = url;
    });
  }

  function addResult(original, blob) {
    const url = URL.createObjectURL(blob);
    const base = original.name.replace(/\.[^.]+$/, '');
    const name = base + '.' + ext(fmt.value);
    const row = document.createElement('div');
    row.className = 'file';
    row.innerHTML =
      '<img class="thumb" src="' + url + '" />' +
      '<div class="fmeta"><div class="fname">' + name + '</div>' +
      '<div class="fsize">' + fmtSize(blob.size) + ' · done</div></div>';
    const a = document.createElement('a');
    a.className = 'dl';
    a.href = url;
    a.download = name;
    a.textContent = 'Download';
    row.appendChild(a);
    filesEl.appendChild(row);
  }
</script>

</body>
</html>
